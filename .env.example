# ---------------------------------------------------------------------------
# Copy this file to .env.local (for local dev) and/or set these in Vercel
# Project Settings -> Environment Variables (for production).
#
# These are ONLY needed for the event crowdsourcing moderation queue in
# PRODUCTION. Without them, local dev falls back to data/pending-events.json.
# The rest of the app (map, services, helplines, eligibility) needs NO env vars.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdxyz.supabase.co
SUPABASE_URL=

# Supabase SERVICE ROLE key (server-side only — never expose in the browser).
# Settings -> API -> service_role secret.
SUPABASE_SERVICE_KEY=

# Telegram bot token from @BotFather (only needed to run the bot in bot/).
TELEGRAM_TOKEN=
